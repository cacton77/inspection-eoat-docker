CONTAINER_NAME=inspection-eoat-docker
ROS_DOMAIN_ID=2
ROS_DISTRO=jazzy
# RMW: rmw_cyclonedds_cpp (default) or rmw_fastrtps_cpp.
# micro-ROS agent in this image is built with FastDDS, so the rest of the
# stack must also be on FastDDS for entities to discover each other.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
USE_GPU=false
USE_SERVICE=true
